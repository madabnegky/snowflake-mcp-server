# Snowflake connection
SNOWFLAKE_ACCOUNT=yourorg-youraccountname
SNOWFLAKE_USER=mcp_service_user
SNOWFLAKE_PASSWORD=your-secure-password
SNOWFLAKE_DATABASE=analytics
SNOWFLAKE_WAREHOUSE=reporting_wh
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=reporting_role

# Comma-separated API keys, one per teammate
# Generate with: openssl rand -hex 32
MCP_API_KEYS=key-for-alice,key-for-bob,key-for-carol

# Port (optional, defaults to 3000)
PORT=3000
